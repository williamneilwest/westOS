wnwest.com, www.wnwest.com {
    handle /cockpit {
        redir * /cockpit/ 308
    }

    handle /cockpit/static/* {
        reverse_proxy https://host.docker.internal:9090 {
            transport http {
                tls_insecure_skip_verify
            }
        }
    }

    handle /cockpit/login {
        uri replace /cockpit/login /login
        reverse_proxy https://host.docker.internal:9090 {
            transport http {
                tls_insecure_skip_verify
            }
        }
    }

    handle /cockpit/logout {
        uri replace /cockpit/logout /logout
        reverse_proxy https://host.docker.internal:9090 {
            transport http {
                tls_insecure_skip_verify
            }
        }
    }

    handle /cockpit/socket {
        uri replace /cockpit/socket /socket
        reverse_proxy https://host.docker.internal:9090 {
            transport http {
                tls_insecure_skip_verify
            }
        }
    }

    handle /cockpit/channel/* {
        uri strip_prefix /cockpit
        reverse_proxy https://host.docker.internal:9090 {
            transport http {
                tls_insecure_skip_verify
            }
        }
    }

    handle_path /cockpit/* {
        reverse_proxy https://host.docker.internal:9090 {
            transport http {
                tls_insecure_skip_verify
            }
        }
    }

    handle {
        reverse_proxy westos-frontend:5173
    }
}

code.wnwest.com {
    reverse_proxy code-server:8080
}
