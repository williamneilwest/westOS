westos.dev {

    # -------------------------
    # AI API
    # -------------------------
    handle_path /api/ai/* {
        reverse_proxy backend:5000
    }

    # -------------------------
    # Backend API
    # -------------------------
    handle /flows* {
        reverse_proxy backend:5000
    }

    handle /plaid* {
        reverse_proxy backend:5000
    }

    handle /auth* {
        reverse_proxy backend:5000
    }

    handle /health {
        reverse_proxy backend:5000
    }

    handle /api/health {
        reverse_proxy backend:5000
    }

    # -------------------------
    # Frontend (React)
    # -------------------------
    handle {
        reverse_proxy frontend:5173
    }
}

webui.westos.dev {
    reverse_proxy open-webui:8080
}
