work.westos.dev {
	handle /api/* {
		reverse_proxy backend:5000
	}

	handle /flows/* {
		reverse_proxy backend:5000
	}

	handle /uploads* {
		reverse_proxy backend:5000
	}

	handle /kb* {
		reverse_proxy backend:5000
	}

	handle {
		reverse_proxy frontend:5173
	}
}

